# =============================================================================
# Risk Horizon — environment configuration
# Copy this file to `.env` (or `.env.local`) and fill in your own values.
#   cp .env.example .env
# Without these, the app still runs fully in MOCK mode using built-in sample data.
# =============================================================================

# -----------------------------------------------------------------------------
# Bright Data — powers LIVE mode (real-time web search + page scraping)
# Required (all three) for the "Live" toggle to fetch real data.
# -----------------------------------------------------------------------------
# API key for the Bright Data "/request" API (a UUID-style token).
# Alternatively, a full proxy URL (https://user:pass@host:port) to use proxy mode.
BRIGHT_DATA_API_KEY=

# Zone name configured in your Bright Data dashboard for the SERP API.
BRIGHT_DATA_SERP_ZONE=serp_api1

# Zone name configured in your Bright Data dashboard for the Web Unlocker.
BRIGHT_DATA_UNLOCKER_ZONE=web_unlocker1

# Optional — Bright Data request endpoint. Defaults to the value below.
BRIGHT_DATA_REQUEST_ENDPOINT=https://api.brightdata.com/request

# Optional — per-request timeout in ms so one slow/dead URL can't stall a batch.
# Defaults to 15000 (15s) if unset.
BRIGHT_DATA_REQUEST_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# LLM provider — powers the risk-report synthesis.
# Configure AT LEAST ONE. Selection priority: AIML > OpenAI > Anthropic.
# If none are set, the app falls back to mock report data.
# -----------------------------------------------------------------------------

# AIML API (recommended — used for the Agentic GPT-5-5 mode).
AIML_API_KEY=
AIML_API_URL=https://api.aimlapi.com/v1/chat/completions

# OpenAI (used if AIML is not set). Model: gpt-4o-mini.
OPENAI_API_KEY=

# Anthropic (used if neither AIML nor OpenAI is set). Model: claude-3-5-sonnet.
ANTHROPIC_API_KEY=
